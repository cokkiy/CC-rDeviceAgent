[service]
service_name = "CC-rDeviceAgent"
device_id = "__DEVICE_ID__"
state_interval_seconds = __STATE_INTERVAL_SECONDS__
watched_processes = []
udp_display_target = "127.0.0.1:9008"
launcher_proxy_path = ""

[control]
listen_addr = "0.0.0.0:50051"

[mqtt]
enabled = true
broker_host = "__BROKER_HOST__"
broker_port = __BROKER_PORT__
telemetry_enabled = true
status_enabled = true

[[mqtt.telemetry_profiles]]
id = "default"
name = "Default Runtime"
enabled = true
collection_interval_ms = 5000
includes = [
  "runtime_basic",
  "runtime_system",
  "runtime_apps",
  "runtime_network",
  "runtime_storage",
]
