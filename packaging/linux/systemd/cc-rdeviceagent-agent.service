[Unit]
Description=CC Rust Station Desktop Agent
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
WorkingDirectory=%h/.local/lib/cc-rdeviceagent
ExecStart=%h/.local/lib/cc-rdeviceagent/cc-rdeviceagent-agent --config %h/.local/lib/cc-rdeviceagent/CC-rDeviceAgent.toml
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
